// Prisma schema for AERIA Hub — Phase 1
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  AGENT
}

enum TripStatus {
  INQUIRY
  QUOTED
  BOOKED
  TRAVELING
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentType {
  PASSPORT
  VISA
  INSURANCE
  TICKET
  VOUCHER
  OTHER
}

enum ReminderType {
  PASSPORT_EXPIRY
  FINAL_PAYMENT
  CUSTOM
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum SegmentType {
  FLIGHT
  HOTEL
  CRUISE
  TRANSFER
  EXCURSION
  CAR_RENTAL
  INSURANCE
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(AGENT)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedClients Client[]      @relation("ClientAgent")
  notes           Note[]
  activityLogs    ActivityLog[]
  assignedTasks   TripTask[]    @relation("TaskAssignee")
}

model Client {
  id      String  @id @default(cuid())
  firstName String
  lastName  String

  primaryEmail   String?
  secondaryEmail String?
  primaryPhone   String?
  secondaryPhone String?

  address       String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  dateOfBirth         DateTime?
  passportNumber      String?
  passportIssueDate   DateTime?
  passportExpiry      DateTime?
  redressNumber       String?
  knownTravelerNumber String?
  nationality         String?

  travelPreferences String?
  dietaryNotes      String?
  mobilityNotes     String?

  status ClientStatus @default(ACTIVE)

  assignedAgentId String?
  assignedAgent   User?   @relation("ClientAgent", fields: [assignedAgentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  travelers       Traveler[]
  trips           Trip[]
  invoices        Invoice[]
  documents       Document[]
  notes           Note[]
  reminders       Reminder[]
  activityLogs    ActivityLog[]
  loyaltyPrograms LoyaltyProgram[]
}

model LoyaltyProgram {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  programName  String
  memberNumber String
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Traveler {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  firstName            String
  lastName              String
  relationshipToClient String?
  dateOfBirth          DateTime?
  passportNumber       String?
  passportExpiry       DateTime?
  nationality          String?
  dietaryNotes         String?
  mobilityNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

model Trip {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  destination String
  startDate   DateTime?
  endDate     DateTime?
  status      TripStatus @default(INQUIRY)
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  totalPrice  Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
  segments TripSegment[]
  tasks    TripTask[]
}

model TripSegment {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type               SegmentType
  title              String
  provider           String?
  confirmationNumber String?
  startDateTime      DateTime?
  endDateTime        DateTime?
  location           String?
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  cost               Int?
  notes              String?
  details            Json?
  /// Manual ordering within a day (or the Unscheduled bucket) — see
  /// groupSegmentsByDay in lib/trip-segments.js. Set to (trip max + 1) at
  /// creation, swapped between neighbors on reorder.
  sortOrder          Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

model TripTask {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  title      String
  dueDate    DateTime?
  assigneeId String?
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completed  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tripId   String?
  trip     Trip?   @relation(fields: [tripId], references: [id])

  invoiceNumber String        @unique
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  amount        Int
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  amountPaid    Int           @default(0)
  status        InvoiceStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id         String       @id @default(cuid())
  clientId   String?
  client     Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  travelerId String?
  traveler   Traveler?    @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  segmentId  String?
  segment    TripSegment? @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  type        DocumentType
  fileName    String
  /// Path relative to the private storage/uploads directory (never served
  /// directly — always through the authenticated /api/documents/[id] route).
  storagePath String
  mimeType    String?
  fileSize    Int?
  expiryDate  DateTime?
  uploadedAt  DateTime     @default(now())
}

model Note {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  body     String

  createdAt DateTime @default(now())
}

model Reminder {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type      ReminderType
  title     String
  dueDate   DateTime
  completed Boolean      @default(false)

  createdAt DateTime @default(now())
}

model Inquiry {
  id     String        @id @default(cuid())
  name   String
  email  String?
  phone  String?
  source String        @default("web_form")
  status InquiryStatus @default(NEW)
  notes  String?

  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  description String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
}
