// Prisma schema for AERIA Hub — Phase 1
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  ADMIN
  AGENT
}

enum TripStatus {
  INQUIRY
  QUOTED
  BOOKED
  TRAVELING
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum PaymentType {
  CC_TO_SUPPLIER
  FUTURE_CRUISE_CREDIT
}

enum CommissionStatus {
  PENDING
  RECEIVED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentType {
  PASSPORT
  VISA
  INSURANCE
  TICKET
  VOUCHER
  OTHER
}

enum ReminderType {
  PASSPORT_EXPIRY
  FINAL_PAYMENT
  CUSTOM
}

enum InquiryStatus {
  NEW
  CONTACTED
  QUALIFIED
  CONVERTED
  LOST
}

enum SegmentType {
  FLIGHT
  HOTEL
  CRUISE
  CIRCUIT
  TRANSFER
  EXCURSION
  CAR_RENTAL
  INSURANCE
  OTHER
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum SupplierCategory {
  AIRLINE
  CRUISE
  HOTEL
  TOUR_OPERATOR
  CAR_RENTAL
  INSURANCE
  TRANSFER
  OTHER
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(AGENT)
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedClients Client[]      @relation("ClientAgent")
  notes           Note[]
  activityLogs    ActivityLog[]
  assignedTasks   TripTask[]    @relation("TaskAssignee")
}

model Client {
  id      String  @id @default(cuid())
  firstName String
  lastName  String

  primaryEmail   String?
  secondaryEmail String?
  primaryPhone   String?
  secondaryPhone String?

  address       String?
  city          String?
  stateProvince String?
  postalCode    String?
  country       String?

  dateOfBirth         DateTime?
  passportNumber      String?
  passportIssueDate   DateTime?
  passportExpiry      DateTime?
  redressNumber       String?
  knownTravelerNumber String?
  nationality         String?

  travelPreferences String?
  dietaryNotes      String?
  mobilityNotes     String?

  status ClientStatus @default(ACTIVE)

  assignedAgentId String?
  assignedAgent   User?   @relation("ClientAgent", fields: [assignedAgentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  travelers       Traveler[]
  trips           Trip[]
  additionalTrips TripClient[]
  invoices        Invoice[]
  documents       Document[]
  notes           Note[]
  reminders       Reminder[]
  activityLogs    ActivityLog[]
  loyaltyPrograms LoyaltyProgram[]
}

model LoyaltyProgram {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  programName  String
  memberNumber String
  notes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Traveler {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  firstName            String
  lastName              String
  relationshipToClient String?
  dateOfBirth          DateTime?
  passportNumber       String?
  passportExpiry       DateTime?
  nationality          String?
  dietaryNotes         String?
  mobilityNotes        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents Document[]
}

model Trip {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name        String
  destination String
  startDate   DateTime?
  endDate     DateTime?
  status      TripStatus @default(INQUIRY)
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  totalPrice  Int?
  finalPaymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices          Invoice[]
  segments          TripSegment[]
  tasks             TripTask[]
  quotes            Quote[]
  payments          TripPayment[]
  /// Clients beyond the primary clientId above — e.g. a second household
  /// traveling together on the same booking.
  additionalClients TripClient[]
}

/// Join row linking a Trip to a Client beyond its primary clientId.
model TripClient {
  id       String @id @default(cuid())
  tripId   String
  trip     Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tripId, clientId])
}

model TripSegment {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type               SegmentType
  title              String
  supplierId         String?
  supplier           Supplier?   @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  confirmationNumber String?
  startDateTime      DateTime?
  endDateTime        DateTime?
  location           String?
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  cost               Int?
  notes              String?
  details            Json?
  /// Manual ordering within a day (or the Unscheduled bucket) — see
  /// groupSegmentsByDay in lib/trip-segments.js. Set to (trip max + 1) at
  /// creation, swapped between neighbors on reorder.
  sortOrder          Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents   Document[]
  commissions SegmentCommission[]
}

/// A travel vendor (airline, cruise line, hotel chain, tour operator...)
/// that trip segments can be booked through. Deleting a supplier detaches
/// it from any segments (segment.supplierId → null) rather than deleting them.
model Supplier {
  id       String           @id @default(cuid())
  name     String
  category SupplierCategory @default(OTHER)

  phone          String?
  website        String?
  agentPortalUrl String?
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  segments TripSegment[]
}

/**
 * A portion of the commission owed to the agency for a segment. Most
 * segments have a single portion due at the trip's end date (client
 * return). Exoticca circuits split into two: 60% due at the trip's
 * booking date, 40% at the client's return — see readCommissionPortions
 * in the segment commission actions.
 */
model SegmentCommission {
  id        String @id @default(cuid())
  segmentId String
  segment   TripSegment @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  amount       Int
  dueDate      DateTime?
  status       CommissionStatus @default(PENDING)
  receivedDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TripTask {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  title      String
  dueDate    DateTime?
  assigneeId String?
  assignee   User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completed  Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  title      String
  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems QuoteLineItem[]
}

model QuoteLineItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description String
  quantity    Int    @default(1)
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  unitPrice   Int
  /// Manual creation order — items display in the order they were added.
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TripPayment {
  id     String @id @default(cuid())
  tripId String
  trip   Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)

  type               PaymentType
  cardHolder         String?
  cardNumber         String?
  confirmationNumber String?
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  amount             Int
  paymentDate        DateTime
  paidTo             String?
  comments           String?
  /// Logical cancellation — cancelled payments are excluded from the
  /// balance calculation but kept for the audit trail, and can be
  /// hidden/shown in the history table via a toggle.
  cancelled          Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id       String  @id @default(cuid())
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tripId   String?
  trip     Trip?   @relation(fields: [tripId], references: [id])

  invoiceNumber String        @unique
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  /// Kept in sync with the sum of lineItems by the invoice line-item
  /// actions — never edited directly by the line-item total.
  amount        Int
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  amountPaid    Int           @default(0)
  status        InvoiceStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems InvoiceLineItem[]
}

/// A priced line on an Invoice — mirrors QuoteLineItem. Populated by
/// copying a trip's segments or a quote's line items at conversion time,
/// and editable afterward.
model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Int    @default(1)
  /// Cents, not dollars — use dollarsToCents/formatCurrency from lib/format.js.
  unitPrice   Int
  sortOrder   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Document {
  id         String       @id @default(cuid())
  clientId   String?
  client     Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  travelerId String?
  traveler   Traveler?    @relation(fields: [travelerId], references: [id], onDelete: Cascade)
  segmentId  String?
  segment    TripSegment? @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  type        DocumentType
  fileName    String
  /// Path relative to the private storage/uploads directory (never served
  /// directly — always through the authenticated /api/documents/[id] route).
  storagePath String
  mimeType    String?
  fileSize    Int?
  expiryDate  DateTime?
  uploadedAt  DateTime     @default(now())
}

model Note {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation(fields: [authorId], references: [id])
  body     String

  createdAt DateTime @default(now())
}

model Reminder {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  type      ReminderType
  title     String
  dueDate   DateTime
  completed Boolean      @default(false)

  createdAt DateTime @default(now())
}

model Inquiry {
  id     String        @id @default(cuid())
  name   String
  email  String?
  phone  String?
  source String        @default("web_form")
  status InquiryStatus @default(NEW)
  notes  String?

  createdAt DateTime @default(now())
}

model ActivityLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  description String?

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
}
